<UserControl x:Class="SkinHolderDesktop.Views.Partials.UserItems"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:local="clr-namespace:SkinHolderDesktop.Views.Partials" 
             xmlns:viewmodels="clr-namespace:SkinHolderDesktop.ViewModels" 
             xmlns:useritem="clr-namespace:SkinHolderDesktop.Views.Partials.UserItemPartials"
             xmlns:behaviors="clr-namespace:SkinHolderDesktop.Behaviors"
             d:DataContext="{d:DesignInstance Type=viewmodels:UserItemsViewModel}"
             mc:Ignorable="d" 
             d:DesignHeight="511" 
             d:DesignWidth="834">
    <UserControl.Resources>
        <ControlTemplate x:Key="LoadingSpinnerTemplate" TargetType="ContentControl">
            <Grid Width="50" Height="50">
                <Ellipse Stroke="#3A3A3A" StrokeThickness="4" Fill="Transparent"/>
                <Ellipse Stroke="{StaticResource PrimaryBrush}" StrokeThickness="4" Fill="Transparent"
                         StrokeDashArray="9 27"
                         StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                         RenderTransformOrigin="0.5,0.5">
                    <Ellipse.RenderTransform>
                        <RotateTransform/>
                    </Ellipse.RenderTransform>
                    <Ellipse.Triggers>
                        <EventTrigger RoutedEvent="Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation
                                        Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                        From="0" To="360"
                                        Duration="0:0:1"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </Ellipse.Triggers>
                </Ellipse>
            </Grid>
        </ControlTemplate>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="3*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ScrollViewer Grid.RowSpan="2"
            VerticalScrollBarVisibility="Hidden"
            HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding FilteredUserItems}" Margin="0 0 0 30">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <useritem:_UserItem />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <ContentControl Grid.RowSpan="2"
                        Template="{StaticResource LoadingSpinnerTemplate}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Panel.ZIndex="10"
                        Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>

        <Border Grid.Column="1" Grid.Row="0" Style="{StaticResource RoundedPanelStyle}" Margin="15 30 30 0">
            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="0.55*"/>
                    <RowDefinition/>
                    <RowDefinition/>
                    <RowDefinition Height="0.55*"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0 0 0 10">
                    <iconPacks:PackIconLucide Kind="Package" Width="24" Height="24" Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center" Margin="0 0 10 0" />
                    <TextBlock Style="{StaticResource TitleTextBlockStyle}" 
                               Foreground="WhiteSmoke" FontSize="20"
                               VerticalAlignment="Center"
                               Text="NUEVO ITEM" />
                </StackPanel>

                <ListBox Grid.Row="1"
                    Grid.RowSpan="2"
                    Grid.ColumnSpan="3"
                    Margin="15 0 15 15"
                    ItemsSource="{Binding FilteredItems}"
                    SelectedItem="{Binding SelectedFilteredItem, Mode=TwoWay}"
                    Background="Transparent"
                    ScrollViewer.VerticalScrollBarVisibility="Hidden"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                    BorderThickness="0"
                    ItemTemplate="{StaticResource ItemNombreTemplate}"
                    ItemContainerStyle="{StaticResource ListBoxItemTransparentStyle}"
                    VirtualizingStackPanel.IsVirtualizing="True"
                    VirtualizingStackPanel.VirtualizationMode="Standard">
                    <ListBox.ToolTip>
                        <ToolTip Content="Selecciona un item de la lista para añadirlo."/>
                    </ListBox.ToolTip>
                </ListBox>

                <Grid Grid.Row="3" Grid.ColumnSpan="3">
                    <TextBox x:Name="SearchBox"
                        Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                        Style="{StaticResource LoginTextBoxStyle}"
                        behaviors:TextBoxSelectAllBehavior.SelectAllOnFocus="True"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Stretch"
                        Padding="36,0,8,0"
                        Margin="0"
                        MaxWidth="340"
                        MaxHeight="45"
                        VerticalContentAlignment="Center"
                        HorizontalContentAlignment="Left">
                        <TextBox.ToolTip>
                            <ToolTip Content="Busca por items" />
                        </TextBox.ToolTip>
                    </TextBox>

                    <iconPacks:PackIconFontAwesome
                        Kind="MagnifyingGlassSolid"
                        Width="18" Height="18"
                        Foreground="{StaticResource PrimaryBrush}"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Left"
                        Margin="30,0,0,0"
                        IsHitTestVisible="False" />
                </Grid>

            </Grid>
        </Border>

        <Border Grid.Column="1" Grid.Row="0"
                CornerRadius="12"
                Background="#CC1C1C1C"
                Margin="15 30 30 0"
                Panel.ZIndex="10"
                Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <ContentControl Template="{StaticResource LoadingSpinnerTemplate}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>
        </Border>

        <StackPanel Grid.Column="1" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Orientation="Horizontal" Margin="15 30 30 30">

            <TextBox 
                Width="150" Height="55" 
                Margin="5" MaxLength="9" 
                HorizontalContentAlignment="Center" 
                VerticalContentAlignment="Center" 
                behaviors:TextBoxSelectAllBehavior.SelectAllOnFocus="True"
                Style="{StaticResource LoginTextBoxStyle}"
                Text="{Binding NewItemNum}">
                <TextBox.ToolTip>
                    <ToolTip Content="Solo números enteros"/>
                </TextBox.ToolTip>
            </TextBox>

            <Button Style="{StaticResource PrimaryButtonStyle}" 
                    Margin="5"
                    Width="200"
                    Command="{Binding AddItemCommand}">
                <StackPanel Style="{StaticResource PrimaryButtonContentStyle}">
                    <iconPacks:PackIconLucide Kind="Plus" Width="18" Height="18" Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center" Margin="0 0 10 0" />
                    <TextBlock Text="AÑADIR ITEM" FontSize="14" FontWeight="SemiBold" Foreground="#E0E0E0" VerticalAlignment="Center" />
                </StackPanel>
            </Button>

        </StackPanel>

    </Grid>
</UserControl>
