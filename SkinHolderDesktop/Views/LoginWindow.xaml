<Window x:Class="SkinHolderDesktop.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:vm="clr-namespace:SkinHolderDesktop.ViewModels" 
        xmlns:behaviors="clr-namespace:SkinHolderDesktop.Behaviors"
        d:DataContext="{d:DesignInstance Type=vm:LoginViewModel}"
        mc:Ignorable="d"
        Title="SkinHolder - Login"
        Height="800"
        Width="600"
        ResizeMode="CanMinimize"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        Background="#4A4A4A"
        BorderBrush="{DynamicResource PrimaryBrush}"
        BorderThickness="1"
        Icon="https://cdn.jagoba.dev/imgs/logo.ico">

    <Window.InputBindings>
        <KeyBinding Key="Enter" Command="{Binding IniciarSesionCommand}" />
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36" />
            <RowDefinition />
            <RowDefinition Height="1.5*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" Background="Transparent">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14 0 0 0">
                <Image x:Name="TitleBarIcon" Width="20" Height="20" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality" />
                <TextBlock Text="SkinHolder" FontSize="12" FontWeight="SemiBold" Foreground="#888888" VerticalAlignment="Center" Margin="8 0 0 0" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Stretch">
                <Button Click="BtnMinimize_Click" Width="46" Focusable="False" IsTabStop="False" ToolTip="Minimizar">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bg" Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bg" Property="Background" Value="#33FFFFFF" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                    <iconPacks:PackIconLucide Kind="Minus" Width="14" Height="14" Foreground="#AAAAAA" />
                </Button>
                <Button Click="BtnClose_Click" Width="46" Focusable="False" IsTabStop="False" ToolTip="Cerrar">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bg" Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bg" Property="Background" Value="#CC3333" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                    <iconPacks:PackIconLucide Kind="X" Width="14" Height="14" Foreground="#AAAAAA" />
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="40 40 40 20">
            <Image Name="Logo" />
            <TextBlock Style="{StaticResource TopMenuTitleTextBlockStyle}" FontSize="45">
                <Run Text="SKINHOLDER" Foreground="{StaticResource PrimaryBrush}" />
            </TextBlock>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource RoundedPanelStyle}" Margin="40 20 40 40">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition Height="30" />
                    <RowDefinition />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="28 20 28 0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Margin="4 0 0 8">
                        <iconPacks:PackIconLucide Kind="User" Width="14" Height="14" Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center" />
                        <TextBlock Text="USUARIO" FontSize="11" FontWeight="SemiBold" Foreground="#999999" VerticalAlignment="Center" Margin="6 0 0 0" />
                    </StackPanel>
                    <TextBox
                        Style="{StaticResource LoginTextBoxStyle}"
                        Text="{Binding UserName, UpdateSourceTrigger=PropertyChanged}"
                        behaviors:TextBoxSelectAllBehavior.SelectAllOnFocus="True" />
                </StackPanel>

                <StackPanel Grid.Row="1" Margin="28 12 28 0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Margin="4 0 0 8">
                        <iconPacks:PackIconLucide Kind="Lock" Width="14" Height="14" Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center" />
                        <TextBlock Text="CONTRASEÑA" FontSize="11" FontWeight="SemiBold" Foreground="#999999" VerticalAlignment="Center" Margin="6 0 0 0" />
                    </StackPanel>
                    <Grid>
                        <PasswordBox
                            x:Name="PasswordBox" Style="{StaticResource LoginPasswordBoxStyle}"
                            PasswordChanged="PasswordBox_PasswordChanged"
                            behaviors:TextBoxSelectAllBehavior.SelectAllOnFocus="True" />
                        <Button Width="32" Height="32" HorizontalAlignment="Right" VerticalAlignment="Center"
                                Margin="0 0 10 0" Padding="0" BorderThickness="0" Background="Transparent"
                                Cursor="Hand" Command="{Binding ToggleGuardarPasswordCommand}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Grid Background="{TemplateBinding Background}">
                                                    <iconPacks:PackIconLucide x:Name="Icon"
                                                        Kind="{Binding GuardarPassword, Converter={StaticResource SaveIconConverter}}"
                                                        Width="18" Height="18"
                                                        Foreground="#777777"
                                                        IsHitTestVisible="False"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center" />
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Icon" Property="Foreground" Value="{StaticResource PrimaryBrush}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </StackPanel>

                <TextBlock Grid.Row="2" Text="{Binding ErrorText}" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0 10 0 0" Foreground="#FF6B6B" FontSize="13" />

                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button Command="{Binding IniciarSesionCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="20 0">
                        <StackPanel Style="{StaticResource PrimaryButtonContentStyle}">
                            <iconPacks:PackIconLucide Kind="LogIn" Width="18" Height="18" Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center" Margin="0 0 10 0" />
                            <TextBlock Text="INICIAR SESIÓN" FontSize="14" FontWeight="SemiBold" Foreground="#E0E0E0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ButtonStyleWithBorderRadius}" Command="{Binding RegistrarCommand}" Width="60" Margin="0 0 20 0">
                        <iconPacks:PackIconLucide Kind="UserPlus" Width="26" Height="26" Foreground="{StaticResource PrimaryBrush}" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
