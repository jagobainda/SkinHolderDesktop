<Window x:Class="SkinHolderDesktop.Views.Shared.RegistroDetails"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:local="clr-namespace:SkinHolderDesktop.Views.Shared" 
        xmlns:viewmodels="clr-namespace:SkinHolderDesktop.ViewModels.Shared" 
        d:DataContext="{d:DesignInstance Type=viewmodels:RegistroDetailsViewModel}"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Height="580"
        Width="1000"
        ResizeMode="CanMinimize"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        Background="#3C3C3C"
        BorderBrush="{DynamicResource PrimaryBrush}"
        BorderThickness="1"
        Icon="https://cdn.jagoba.dev/imgs/logo.ico">

    <Window.Resources>
        <Style x:Key="SortHeaderButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="Gray"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2A2A2A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#3A3A3A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" Background="Transparent">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14 0 0 0">
                <Image x:Name="TitleBarIcon" Width="20" Height="20" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality" />
                <TextBlock Text="SkinHolder" FontSize="12" FontWeight="SemiBold" Foreground="#888888" VerticalAlignment="Center" Margin="8 0 0 0" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Stretch">
                <Button Click="BtnMinimize_Click" Width="46" Focusable="False" IsTabStop="False" ToolTip="Minimizar">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bg" Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bg" Property="Background" Value="#33FFFFFF" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                    <iconPacks:PackIconLucide Kind="Minus" Width="14" Height="14" Foreground="#AAAAAA" />
                </Button>
                <Button Click="BtnClose_Click" Width="46" Focusable="False" IsTabStop="False" ToolTip="Cerrar">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bg" Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bg" Property="Background" Value="#CC3333" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                    <iconPacks:PackIconLucide Kind="X" Width="14" Height="14" Foreground="#AAAAAA" />
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" 
                Margin="0 0 0 15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                    Background="#252525"
                    CornerRadius="8"
                    BorderBrush="{StaticResource PrimaryBrush}"
                    BorderThickness="0,2,0,0"
                    Padding="15,10"
                    Margin="0,0,6,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="FECHA DE CONSULTA" 
                       FontWeight="SemiBold" 
                       Foreground="#888888" 
                       FontSize="11"
                       HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding FechaRegistro}" 
                       Foreground="WhiteSmoke" 
                       FontSize="16"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                    Background="#252525"
                    CornerRadius="8"
                    BorderBrush="{StaticResource SteamBrush}"
                    BorderThickness="0,2,0,0"
                    Padding="15,10"
                    Margin="6,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="TOTAL STEAM" 
                       FontWeight="SemiBold" 
                       Foreground="{StaticResource SteamBrush}" 
                       FontSize="11"
                       HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalSteamFormatted}" 
                       Foreground="{StaticResource SteamBrush}" 
                       FontSize="18" 
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                    Background="#252525"
                    CornerRadius="8"
                    BorderBrush="{StaticResource GamerPayBrush}"
                    BorderThickness="0,2,0,0"
                    Padding="15,10"
                    Margin="6,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="TOTAL GAMERPAY" 
                       FontWeight="SemiBold" 
                       Foreground="{StaticResource GamerPayBrush}" 
                       FontSize="11"
                       HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalGamerPayFormatted}" 
                       Foreground="{StaticResource GamerPayBrush}" 
                       FontSize="18" 
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="3"
                    Background="#252525"
                    CornerRadius="8"
                    BorderBrush="#666666"
                    BorderThickness="0,2,0,0"
                    Padding="15,10"
                    Margin="6,0,0,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="TOTAL CSFLOAT" 
                       FontWeight="SemiBold" 
                       Foreground="#AAAAAA" 
                       FontSize="11"
                       HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalCSFloatFormatted}" 
                       Foreground="WhiteSmoke" 
                       FontSize="18" 
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="1" 
                Style="{StaticResource RoundedPanelStyle}"
                Margin="0"
                Padding="0">

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" 
                            Background="#222222" 
                            CornerRadius="12,12,0,0"
                            Padding="20,14"
                            BorderBrush="#3A3A3A"
                            BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="130"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0" 
                                    Style="{StaticResource SortHeaderButtonStyle}"
                                    Command="{Binding SortByNombreCommand}"
                                    HorizontalAlignment="Left">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="ARTÍCULO" Margin="15,0,0,0"/>
                                    <TextBlock Text="{Binding NombreSortIndicator}" 
                                               Foreground="{StaticResource PrimaryBrush}"/>
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="1" 
                                    Style="{StaticResource SortHeaderButtonStyle}"
                                    Command="{Binding SortByCantidadCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="CANTIDAD" Margin="0,0,5,0"/>
                                    <TextBlock Text="{Binding CantidadSortIndicator}" 
                                               Foreground="{StaticResource PrimaryBrush}"/>
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="2" 
                                    Style="{StaticResource SortHeaderButtonStyle}"
                                    Command="{Binding SortBySteamCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="STEAM" 
                                               Foreground="{StaticResource SteamBrush}" 
                                               Margin="0,0,5,0"/>
                                    <TextBlock Text="{Binding SteamSortIndicator}" 
                                               Foreground="{StaticResource PrimaryBrush}"/>
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="3" 
                                    Style="{StaticResource SortHeaderButtonStyle}"
                                    Command="{Binding SortByGamerPayCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="GAMERPAY" 
                                               Foreground="{StaticResource GamerPayBrush}" 
                                               Margin="0,0,5,0"/>
                                    <TextBlock Text="{Binding GamerPaySortIndicator}" 
                                               Foreground="{StaticResource PrimaryBrush}"/>
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="4" 
                                    Style="{StaticResource SortHeaderButtonStyle}"
                                    Command="{Binding SortByCSFloatCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="CSFLOAT" 
                                               Foreground="{StaticResource CSFloatBrushSecondary}" 
                                               Margin="0,0,5,0"/>
                                    <TextBlock Text="{Binding CsFloatSortIndicator}" 
                                               Foreground="{StaticResource PrimaryBrush}"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1" 
                                  VerticalScrollBarVisibility="Hidden" 
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="20 5 20 20">
                        <ItemsControl ItemsSource="{Binding ItemsDetalle}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,1" 
                                            Padding="0,10" 
                                            CornerRadius="6">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="BorderThickness" Value="3,0,0,0"/>
                                                <Setter Property="BorderBrush" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#383838"/>
                                                        <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="3*"/>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="130"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" 
                                                       Text="{Binding ItemName}" 
                                                       Foreground="WhiteSmoke" 
                                                       FontSize="14" 
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding ItemName}" Margin="12,0,0,0"/>

                                            <TextBlock Grid.Column="1" 
                                                       Text="{Binding Cantidad}" 
                                                       Foreground="{StaticResource PrimaryBrush}" 
                                                       FontWeight="Bold" 
                                                       FontSize="14" 
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>

                                            <TextBlock Grid.Column="2" 
                                                       Text="{Binding PrecioSteamFormatted}" 
                                                       Foreground="{StaticResource SteamBrush}" 
                                                       FontSize="13" 
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       ToolTip="{Binding TotalSteamFormatted}"/>

                                            <TextBlock Grid.Column="3" 
                                                       Text="{Binding PrecioGamerPayFormatted}" 
                                                       Foreground="{StaticResource GamerPayBrush}" 
                                                       FontSize="13" 
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       ToolTip="{Binding TotalGamerPayFormatted}"/>

                                            <TextBlock Grid.Column="4" 
                                                       Text="{Binding PrecioCSFloatFormatted}" 
                                                       Foreground="{StaticResource CSFloatBrushSecondary}" 
                                                       FontSize="13" 
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       ToolTip="{Binding TotalCSFloatFormatted}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>