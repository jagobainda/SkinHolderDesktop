<Window x:Class="SkinHolderDesktop.Views.Shared.RegistroList"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:local="clr-namespace:SkinHolderDesktop.Views.Shared"
        xmlns:viewmodels="clr-namespace:SkinHolderDesktop.ViewModels.Shared"
        d:DataContext="{d:DesignInstance Type=viewmodels:RegistroListViewModel}"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Height="600"
        Width="950"
        ResizeMode="CanMinimize"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        Background="#3C3C3C"
        BorderBrush="{DynamicResource PrimaryBrush}"
        BorderThickness="1"
        Icon="https://cdn.jagoba.dev/imgs/logo.ico">

    <Window.Resources>
        <Style x:Key="SortHeaderButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="Gray"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2A2A2A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#3A3A3A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" Background="Transparent">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14 0 0 0">
                <Image x:Name="TitleBarIcon" Width="20" Height="20" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality" />
                <TextBlock Text="SkinHolder" FontSize="12" FontWeight="SemiBold" Foreground="#888888" VerticalAlignment="Center" Margin="8 0 0 0" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Stretch">
                <Button Click="BtnMinimize_Click" Width="46" Focusable="False" IsTabStop="False" ToolTip="Minimizar">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bg" Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bg" Property="Background" Value="#33FFFFFF" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                    <iconPacks:PackIconLucide Kind="Minus" Width="14" Height="14" Foreground="#AAAAAA" />
                </Button>
                <Button Click="BtnClose_Click" Width="46" Focusable="False" IsTabStop="False" ToolTip="Cerrar">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bg" Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bg" Property="Background" Value="#CC3333" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                    <iconPacks:PackIconLucide Kind="X" Width="14" Height="14" Foreground="#AAAAAA" />
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

        <Border Grid.Row="0" Grid.RowSpan="2" 
                Background="#CC000000" 
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"
                Panel.ZIndex="999"
                CornerRadius="12">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <iconPacks:PackIconLucide Kind="LoaderCircle" Width="36" Height="36"
                                          Foreground="{StaticResource PrimaryBrush}"
                                          HorizontalAlignment="Center"/>
                <TextBlock Text="Cargando..." 
                           Foreground="#CCFFFFFF" 
                           FontSize="14" 
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="0" 
                Style="{StaticResource RoundedPanelStyle}"
                Margin="0 0 0 15"
                Padding="20,14">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="{Binding Title}" 
                           Foreground="{StaticResource PrimaryBrush}" 
                           FontSize="22" 
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>
                <Border Background="{StaticResource PrimaryBrush}" 
                        Height="2" 
                        CornerRadius="1" 
                        Margin="30,6,30,0" 
                        Opacity="0.5"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" 
                Style="{StaticResource RoundedPanelStyle}"
                Margin="0"
                Padding="0">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" 
                        Background="#222222" 
                        CornerRadius="12,12,0,0"
                        Padding="20,14"
                        BorderBrush="#3A3A3A"
                        BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0" 
                                Style="{StaticResource SortHeaderButtonStyle}"
                                Command="{Binding SortByFechaCommand}"
                                HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="FECHA" Margin="15,0,5,0"/>
                                <TextBlock Text="{Binding FechaSortIndicator}" 
                                           Foreground="{StaticResource PrimaryBrush}"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="1" 
                                Style="{StaticResource SortHeaderButtonStyle}"
                                Command="{Binding SortBySteamCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="STEAM" 
                                           Foreground="{StaticResource SteamBrush}" 
                                           Margin="0,0,5,0"/>
                                <TextBlock Text="{Binding SteamSortIndicator}" 
                                           Foreground="{StaticResource PrimaryBrush}"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="2" 
                                Style="{StaticResource SortHeaderButtonStyle}"
                                Command="{Binding SortByGamerPayCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="GAMERPAY" 
                                           Foreground="{StaticResource GamerPayBrush}" 
                                           Margin="0,0,5,0"/>
                                <TextBlock Text="{Binding GamerPaySortIndicator}" 
                                           Foreground="{StaticResource PrimaryBrush}"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="3" 
                                Style="{StaticResource SortHeaderButtonStyle}"
                                Command="{Binding SortByCSFloatCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="CSFLOAT" 
                                           Foreground="{StaticResource CSFloatBrushSecondary}" 
                                           Margin="0,0,5,0"/>
                                <TextBlock Text="{Binding CsFloatSortIndicator}" 
                                           Foreground="{StaticResource PrimaryBrush}"/>
                            </StackPanel>
                        </Button>

                        <TextBlock Grid.Column="4" 
                                   Text="ACCIONES" 
                                   Foreground="Gray"
                                   FontWeight="Bold"
                                   FontSize="13"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Margin="0,0,15,0"/>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" 
                              VerticalScrollBarVisibility="Hidden" 
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="20 5 20 20">
                    <ItemsControl ItemsSource="{Binding Registros}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,1" 
                                        Padding="0,13" 
                                        CornerRadius="6">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="3,0,0,0"/>
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#383838"/>
                                                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" 
                                                   Text="{Binding FechaFormatted}" 
                                                   Foreground="WhiteSmoke" 
                                                   FontSize="14" 
                                                   FontWeight="Bold"
                                                   VerticalAlignment="Center"
                                                   Margin="10,0,0,0"/>

                                        <TextBlock Grid.Column="1" 
                                                   Text="{Binding SteamFormatted}" 
                                                   Foreground="{StaticResource SteamBrush}" 
                                                   FontSize="14" 
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="2" 
                                                   Text="{Binding GamerPayFormatted}" 
                                                   Foreground="{StaticResource GamerPayBrush}" 
                                                   FontSize="14" 
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="3" 
                                                   Text="{Binding CSFloatFormatted}" 
                                                   Foreground="{StaticResource CSFloatBrushSecondary}" 
                                                   FontSize="14" 
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>

                                        <StackPanel Grid.Column="4" 
                                                    Orientation="Horizontal" 
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Center"
                                                    Margin="0,0,5,0">
                                            <Button Style="{StaticResource ButtonStyleWithBorderRadius}" 
                                                    Width="60" 
                                                    Height="40" 
                                                    Margin="5,0"
                                                    Command="{Binding DataContext.VerDetallesCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding Registroid}"
                                                    ToolTip="Ver detalles">
                                                <iconPacks:PackIconLucide Kind="Eye" 
                                                                                Width="20" 
                                                                                Height="20" 
                                                                                Foreground="{StaticResource PrimaryBrush}" />
                                            </Button>

                                            <Button Style="{StaticResource ButtonStyleWithBorderRadius}" 
                                                    Width="60" 
                                                    Height="40" 
                                                    Margin="5,0"
                                                    Command="{Binding DataContext.EliminarRegistroCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding Registroid}"
                                                    ToolTip="Eliminar registro">
                                                <iconPacks:PackIconLucide Kind="Trash2"  
                                                                                Width="20" 
                                                                                Height="20" 
                                                                                Foreground="#E74C3C" />
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
        </Grid>
    </Grid>
</Window>
