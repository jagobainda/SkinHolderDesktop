<Window x:Class="SkinHolderDesktop.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:local="clr-namespace:SkinHolderDesktop" 
        xmlns:vm="clr-namespace:SkinHolderDesktop.ViewModels" 
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        mc:Ignorable="d"
        Title="SkinHolder"
        Height="650"
        Width="1000"
        ResizeMode="CanMinimize"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        BorderBrush="{DynamicResource PrimaryBrush}"
        BorderThickness="1"
        Icon="https://cdn.jagoba.dev/imgs/logo.ico">
    
    <Window.Resources>

        <Style x:Key="ButtonStyleWithBorderRadius" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="0" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#444444"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Background" Value="#888888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="#B8D600"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="90"/>
            <Setter Property="Height" Value="90"/>
        </Style>

    </Window.Resources>

    <Grid Background="#4A4A4A">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="100"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Grid.ColumnSpan="2" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" Background="Transparent">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14 0 0 0">
                <Image x:Name="TitleBarIcon" Width="20" Height="20" VerticalAlignment="Center" RenderOptions.BitmapScalingMode="HighQuality" />
                <TextBlock Text="SkinHolder" FontSize="12" FontWeight="SemiBold" Foreground="#888888" VerticalAlignment="Center" Margin="8 0 0 0" />
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Stretch">
                <Button Click="BtnMinimize_Click" Width="46" Focusable="False" IsTabStop="False" ToolTip="Minimizar">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bg" Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bg" Property="Background" Value="#33FFFFFF" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                    <iconPacks:PackIconLucide Kind="Minus" Width="14" Height="14" Foreground="#AAAAAA" />
                </Button>
                <Button Click="BtnClose_Click" Width="46" Focusable="False" IsTabStop="False" ToolTip="Cerrar">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bg" Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bg" Property="Background" Value="#CC3333" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                    <iconPacks:PackIconLucide Kind="X" Width="14" Height="14" Foreground="#AAAAAA" />
                </Button>
            </StackPanel>
        </Grid>

        <Grid Name="GridBarraSuperior" Grid.Row="1" Grid.ColumnSpan="2" Grid.Column="0" Background="#383838">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="1.5*"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="20 0">
                <StackPanel Orientation="Horizontal" Margin="0 0 0 6">
                    <iconPacks:PackIconLucide Kind="Database" Width="12" Height="12" Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center" />
                    <TextBlock Text="SKINHOLDERDB" FontSize="10" FontWeight="SemiBold" Foreground="#777777" VerticalAlignment="Center" Margin="7 0 0 0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <StackPanel Margin="0 0 24 0">
                        <TextBlock Text="ESTADO" FontSize="10" Foreground="#666666" />
                        <TextBlock Text="{Binding EstadoSkinHolderDb}" FontSize="14" FontWeight="SemiBold" Foreground="{Binding EstadoSkinHolderDbBrush}" />
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="PING" FontSize="10" Foreground="#666666" />
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding SkinHolderDbPing}" FontSize="14" FontWeight="SemiBold" Foreground="{Binding SkinHolderDbPingBrush}" />
                            <TextBlock Text=" ms" FontSize="11" Foreground="#666666" VerticalAlignment="Bottom" Margin="2 0 0 2" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <Rectangle Grid.Column="1" Fill="#4A4A4A" Margin="0 16" />

            <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="20 0">
                <StackPanel Orientation="Horizontal" Margin="0 0 0 6">
                    <iconPacks:PackIconLucide Kind="Clock" Width="12" Height="12" Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center" />
                    <TextBlock Text="ÚLTIMO REGISTRO" FontSize="10" FontWeight="SemiBold" Foreground="#777777" VerticalAlignment="Center" Margin="7 0 0 0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <StackPanel Margin="0 0 24 0">
                        <TextBlock Text="STEAM" FontSize="10" Foreground="#666666" />
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding SteamLast}" FontSize="14" FontWeight="SemiBold" Foreground="#DDDDDD" />
                            <TextBlock Text=" €" FontSize="11" Foreground="#666666" VerticalAlignment="Bottom" Margin="2 0 0 2" />
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Margin="0 0 24 0">
                        <TextBlock Text="GAMERPAY" FontSize="10" Foreground="#666666" />
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding GamerPayLast}" FontSize="14" FontWeight="SemiBold" Foreground="#DDDDDD" />
                            <TextBlock Text=" €" FontSize="11" Foreground="#666666" VerticalAlignment="Bottom" Margin="2 0 0 2" />
                        </StackPanel>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="CSFLOAT" FontSize="10" Foreground="#666666" />
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding CsFloatLast}" FontSize="14" FontWeight="SemiBold" Foreground="#DDDDDD" />
                            <TextBlock Text=" €" FontSize="11" Foreground="#666666" VerticalAlignment="Bottom" Margin="2 0 0 2" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </StackPanel>

            <Rectangle Grid.Column="3" Fill="#4A4A4A" Margin="0 16" />

            <StackPanel Grid.Column="4" VerticalAlignment="Center" Margin="20 0">
                <StackPanel Orientation="Horizontal" Margin="0 0 0 6">
                    <iconPacks:PackIconLucide Kind="Activity" Width="12" Height="12" Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center" />
                    <TextBlock Text="LATENCIA" FontSize="10" FontWeight="SemiBold" Foreground="#777777" VerticalAlignment="Center" Margin="7 0 0 0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <StackPanel Margin="0 0 24 0">
                        <TextBlock Text="STEAM" FontSize="10" Foreground="#666666" />
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding SteamPing}" FontSize="14" FontWeight="SemiBold" Foreground="{Binding SteamPingBrush}" />
                            <TextBlock Text=" ms" FontSize="11" Foreground="#666666" VerticalAlignment="Bottom" Margin="2 0 0 2" />
                        </StackPanel>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="GAMERPAY" FontSize="10" Foreground="#666666" />
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding GamerPayPing}" FontSize="14" FontWeight="SemiBold" Foreground="{Binding GamerPayPingBrush}" />
                            <TextBlock Text=" ms" FontSize="11" Foreground="#666666" VerticalAlignment="Bottom" Margin="2 0 0 2" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </StackPanel>

        </Grid>

        <Grid Name="GridBarraMenuIzquierda" Grid.Column="0" Grid.Row="2" Background="#555555">

            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="2"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="2"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="2"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Button Style="{StaticResource ButtonStyleWithBorderRadius}" Command="{Binding CargarRegistrosCommand}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <iconPacks:PackIconLucide Kind="BookOpen" Width="34" Height="34" Foreground="{StaticResource PrimaryBrush}" />
                    </StackPanel>
                </Button>
            </Grid>

            <Label Grid.Row="1" Background="{StaticResource PrimaryBrush}" Margin="20, 0, 20, 0"/>

            <Grid Grid.Row="2">
                <Button Style="{StaticResource ButtonStyleWithBorderRadius}" Command="{Binding CargarItemsCommand}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <iconPacks:PackIconLucide Kind="List" Width="34" Height="34" Foreground="{StaticResource PrimaryBrush}" />
                    </StackPanel>
                </Button>
            </Grid>

            <Label Grid.Row="3" Background="{StaticResource PrimaryBrush}" Margin="20, 0, 20, 0"/>

            <Grid Grid.Row="4">
                <Button Style="{StaticResource ButtonStyleWithBorderRadius}" Command="{Binding CargarPerfilCommand}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <iconPacks:PackIconLucide Kind="User" Width="34" Height="34" Foreground="{StaticResource PrimaryBrush}" />
                    </StackPanel>
                </Button>
            </Grid>

            <Label Grid.Row="5" Background="{StaticResource PrimaryBrush}" Margin="20, 0, 20, 0"/>

            <Grid Grid.Row="6">
                <Button Style="{StaticResource ButtonStyleWithBorderRadius}" Command="{Binding SalirCommand}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <iconPacks:PackIconLucide Kind="LogOut" Width="34" Height="34" Foreground="{StaticResource PrimaryBrush}" />
                    </StackPanel>
                </Button>
            </Grid>

        </Grid>

        <ContentControl x:Name="ContenedorUserControl" Grid.Column="1" Grid.Row="2" Content="{Binding CurrentContent}">
            <!-- Dynamic content -->
        </ContentControl>
    </Grid>
</Window>
